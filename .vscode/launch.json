{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "LotofacilMcp.Server",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/LotofacilMcp.Server/bin/Debug/net10.0/LotofacilMcp.Server.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/LotofacilMcp.Server",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5247"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s"
            }
        }
    ]
}
